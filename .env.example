# ShadowEngine Environment Variables
# Copy this file to .env and fill in values as needed.

# LLM Backend: "ollama" (default, local), "openai", or "mock" (testing)
LLM_BACKEND=ollama

# Model name (Ollama model or OpenAI model)
LLM_MODEL=llama3.2

# Ollama server URL (only used when LLM_BACKEND=ollama)
OLLAMA_HOST=http://localhost:11434

# OpenAI API key (only used when LLM_BACKEND=openai)
# OPENAI_API_KEY=sk-your-key-here

# LLM generation parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=256
LLM_TIMEOUT=30
